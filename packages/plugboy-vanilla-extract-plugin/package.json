{
  "name": "@fastkit/plugboy-vanilla-extract-plugin",
  "version": "4.0.0",
  "description": "",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadajam4/fastkit.git"
  },
  "license": "MIT",
  "author": "dadajam4",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/plugboy-vanilla-extract-plugin.d.mts",
      "import": {
        "default": "./dist/plugboy-vanilla-extract-plugin.mjs"
      }
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": {
        "default": "./dist/vite.mjs"
      }
    },
    "./*": "./dist/*"
  },
  "main": "./dist/plugboy-vanilla-extract-plugin.mjs",
  "types": "./dist/plugboy-vanilla-extract-plugin.d.mts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/plugboy-vanilla-extract-plugin.d.mts"
      ],
      "vite": [
        "./dist/vite.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "plugboy build",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "format": "pnpm run eslint:fix",
    "lint": "pnpm run eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vanilla-extract/rollup-plugin": "^1.5.3"
  },
  "devDependencies": {
    "@fastkit/plugboy": "workspace:^",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "@fastkit/plugboy": "workspace:^",
    "@vanilla-extract/vite-plugin": "^5.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "@vanilla-extract/vite-plugin": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}