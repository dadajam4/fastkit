{
  "name": "fastkit",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "description": "",
  "scripts": {
    "build:plugboy": "turbo run build --filter=@fastkit/plugboy* --cache-dir=./.turbo-cache",
    "clean": "pnpm -r run clean && rm -rf node_modules && rm -rf .turbo && rm -rf .turbo-cache",
    "reset": "pnpm clean && pnpm i",
    "dev:docs": "cd ./apps/docs && pnpm dev",
    "dev": "pnpm build && pnpm dev:docs",
    "build": "pnpm build:plugboy && turbo run build --log-order=stream --filter=@fastkit/* --filter=!@fastkit/plugboy* --cache-dir=./.turbo-cache",
    "build:force": "rm -rf .turbo-cache && pnpm build",
    "build:docs": "pnpm run build:plugboy && turbo run build --filter=docs --cache-dir=./.turbo-cache",
    "preview:docs": "pnpm build:docs && cd apps/docs && pnpm serve",
    "ci:version": "changeset version",
    "ci:publish": "pnpm build && changeset publish",
    "lint": "turbo run lint --cache-dir=./.turbo-cache",
    "format": "turbo run format --cache-dir=./.turbo-cache",
    "typecheck": "turbo run typecheck --cache-dir=./.turbo-cache",
    "typecheck:packages": "turbo run typecheck --filter=!docs --cache-dir=./.turbo-cache",
    "plugboy": "plugboy",
    "gen": "pnpm run plugboy gen",
    "play": "tsx play.ts",
    "test": "turbo run test --concurrency 1 --cache-dir=./.turbo-cache"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dadajam4/fastkit.git"
  },
  "author": "dadajam4",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@fastkit/color-scheme": "workspace:^",
    "@fastkit/color-scheme-gen": "workspace:^",
    "@fastkit/eslint-config": "workspace:^",
    "@fastkit/eslint-config-vue": "workspace:^",
    "@fastkit/ev": "workspace:^",
    "@fastkit/node-util": "workspace:^",
    "@fastkit/plugboy": "workspace:^",
    "@fastkit/plugboy-sass-plugin": "workspace:^",
    "@fastkit/plugboy-vanilla-extract-plugin": "workspace:^",
    "@fastkit/plugboy-vue-jsx-plugin": "workspace:^",
    "@fastkit/plugboy-vue-plugin": "workspace:^",
    "@fastkit/scroller": "workspace:^",
    "@fastkit/stylelint-config": "workspace:^",
    "@fastkit/stylelint-config-vue": "workspace:^",
    "@fastkit/ts-tiny-meta": "workspace:^",
    "@fastkit/vanilla-extract-utils": "workspace:^",
    "@fastkit/vite-plugin-vui": "workspace:^",
    "@fastkit/vot": "workspace:^",
    "@fastkit/vot-i18n": "workspace:^",
    "@fastkit/vue-i18n": "workspace:^",
    "@fastkit/vue-page": "workspace:^",
    "@fastkit/vue-tiny-meta": "workspace:^",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.2",
    "@types/prismjs": "^1.26.6",
    "@unhead/ssr": "^3.1.3",
    "@unhead/vue": "^3.1.3",
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/css-utils": "^0.1.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/runtime-core": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "baseline-browser-mapping": "^2.10.40",
    "cookie": "^1.1.1",
    "eslint": "^10.6.0",
    "eslint-plugin-prettier": "^5.5.6",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "load-tsconfig": "^0.2.5",
    "postcss": "^8.5.15",
    "postcss-modules": "^6.0.1",
    "prettier": "^3.8.4",
    "prismjs": "^1.30.0",
    "rollup": "^4.62.2",
    "set-cookie-parser": "^3.1.1",
    "stylelint": "^17.14.0",
    "stylelint-prettier": "^5.0.3",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.4"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.16.0",
    "npm": "use pnpm",
    "pnpm": ">=11",
    "yarn": "use pnpm"
  }
}
